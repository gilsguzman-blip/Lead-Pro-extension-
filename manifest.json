{
  "manifest_version": 3,
  "name": "Lead Pro",
  "version": "8.07",
  "description": "AI-powered BDC Lead Response Generator for VinSolutions CRM",
  "permissions": [
    "activeTab",
    "scripting",
    "storage",
    "clipboardWrite",
    "tabs",
    "sidePanel"
  ],
  "host_permissions": [
    "https://*.vinsolutions.com/*",
    "https://*.coxautoinc.com/*",
    "https://generativelanguage.googleapis.com/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://*.vinsolutions.com/*",
        "https://*.coxautoinc.com/*"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_idle",
      "all_frames": true
    }
  ],
  "side_panel": {
    "default_path": "popup.html"
  },
  "action": {
    "default_popup": "popup.html"
  },
  "icons": {
    "16": "icon128.png",
    "48": "icon128.png",
    "128": "icon128.png"
  }
}